node_modules/
.npm/
.DS_Store
*.log
.env

# Vidéos enregistrées par les invités : ignorées par défaut (poids +
# RGPD). On garde uniquement la vidéo de démo versionnée pour repartir
# avec quelque chose après un clone fresh. Ajouter ici une exception
# explicite si on veut versionner d'autres vidéos.
uploads/videos/*
!uploads/videos/.gitkeep

# Corbeille des vidéos soft-supprimées (déplacées depuis videos.html).
# Le dossier est recréé automatiquement au boot par server.js,
# inutile de le versionner. Règle explicite pour la lisibilité même
# si techniquement déjà couverte par "uploads/videos/*" ci-dessus.
uploads/videos/deleted/
